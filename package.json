{
  "name": "proyecto-puntos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:backend": "npm install --prefix backend && npm run build --prefix backend",
    "start:backend": "node backend/dist/src/server.js",
    "build": "npm run build:backend",
    "start": "npm run start:backend",
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "seed": "npm run seed --prefix backend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently -n back,front -c blue,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "setup": "npm run install:all && npm run seed"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
